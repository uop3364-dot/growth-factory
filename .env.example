# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/growthfactory

# Web (use http://localhost:3000 for local dev; production uses https://creatoraitools.tools)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics (optional — only injected when set)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- LLM Configuration ---
# Provider: set to "mock" for dev without API calls
# In production, remove this or set to "openai"
LLM_PROVIDER=mock

# OpenAI API key (required for real AI generation in production)
# OPENAI_API_KEY=sk-...

# OpenAI model (default: gpt-4o-mini — cheapest option that supports JSON mode)
# OPENAI_MODEL=gpt-4o-mini

# --- Fallback Safety ---
# Set to "true" ONLY in local dev to allow deterministic fallback content
# In production, this MUST be unset or "false" — otherwise users get fake template content
ALLOW_FAKE_FALLBACK=true

# --- Cost Controls ---
# Monthly LLM budget in USD. When reached, generation returns an error instead of calling the API.
# Unset = no limit. Recommended starting value for low-traffic: 10
# MONTHLY_LLM_BUDGET_USD=10

# Max requests per minute per IP (default: 5)
# RATE_LIMIT_PER_MINUTE=5

# Cache TTL in minutes (default: 60). Same inputs served from cache within this window.
# CACHE_TTL_MINUTES=60

# --- Feedback System ---
# Email to receive feedback notifications (via Resend)
# FEEDBACK_NOTIFICATION_EMAIL=you@example.com

# Resend API key for sending feedback notification emails
# RESEND_API_KEY=re_...
